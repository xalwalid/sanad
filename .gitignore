app/**/*.iml

# Generated native folders are recreated by CI (flutter create). Keep lib/ + assets/ only.

# --- secrets / signing (never commit) ---
**/key.properties
**/*.keystore
**/*.jks
**/google-services.json
**/GoogleService-Info.plist
.env
.env.*

# --- design hand-off archive (the unpacked folder is kept; the zip is not) ---
Recovery app design integration*.zip

# --- OS / editor ---
.DS_Store
Thumbs.db
*.tmp

# --- helper scripts / logs (local only) ---
_push_to_github.bat
_push_update.bat
_install_flutter.bat
_push_log.txt
app/assets/.writetest
