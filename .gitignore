# --- Flutter / Dart (app/) ---
app/.dart_tool/
app/.flutter-plugins
app/.flutter-plugins-dependencies
app/build/
app/pubspec.lock
app/.idea/
app/ios/
app/android/
app/macos/
app/linux/
app/windows/
app/web/
app/**/GeneratedPluginRegistrant.*
